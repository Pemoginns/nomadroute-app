# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NomadRoute

# Database
DATABASE_URL=postgresql://nomadroute:nomadroute@localhost:5432/nomadroute

# Redis
REDIS_URL=redis://localhost:6379

# Auth (NextAuth)
NEXTAUTH_SECRET=your-secret-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Affiliate Partner IDs
HOSTELWORLD_AFFILIATE_ID=your_hostelworld_id
BOOKING_AFFILIATE_ID=your_booking_id
KIWI_AFFILIATE_ID=your_kiwi_id
SKYSCANNER_AFFILIATE_ID=your_skyscanner_id

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# AI (optional - premium features)
ANTHROPIC_API_KEY=your_anthropic_key

# Email (optional)
RESEND_API_KEY=your_resend_key
